# ==============================
# MOD ZONE BACKEND - ENV CONFIG
# ==============================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=modzone
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Secret (đổi thành chuỗi ngẫu nhiên dài ít nhất 32 ký tự)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS - Thêm domain frontend của bạn
CORS_ORIGINS=http://localhost:3000,https://your-site.netlify.app

# Admin mặc định (tạo lần đầu)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_EMAIL=admin@modzone.vn
